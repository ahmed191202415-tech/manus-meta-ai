META_API_VERSION=v23.0
META_GRAPH_BASE=https://graph.facebook.com

# Optional global Meta app values. In the multi-tenant portal flow,
# each client can save their own Meta App inside the portal.
META_APP_ID=
META_APP_SECRET=
META_TEST_ACCESS_TOKEN=

PUBLIC_BASE_URL=https://your-domain.com
META_OAUTH_REDIRECT_URI=
META_OAUTH_SCOPES=ads_management,ads_read,business_management,leads_retrieval,pages_show_list,pages_read_engagement,pages_manage_posts,pages_manage_engagement

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=
GOOGLE_OAUTH_SCOPES=https://www.googleapis.com/auth/analytics.readonly

SESSION_SECRET=change-this-in-production
PORTAL_PATH=/portal
PORTAL_INVITE_SALT=portal-invite

ADMIN_API_KEY=
ADMIN_EMAIL=
ADMIN_PASSWORD=

GPT_OAUTH_CLIENT_ID=gpt_client_1
GPT_OAUTH_CLIENT_SECRET=

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

HTTP_TIMEOUT=90
DEFAULT_PAGE_LIMIT=100
DEFAULT_MAX_PAGES=20
ANALYSIS_PAGE_LIMIT=100
ANALYSIS_MAX_PAGES=3
ANALYSIS_DEFAULT_DATE_PRESET=last_7d
META_RETRY_MAX_ATTEMPTS=4
META_RETRY_BASE_DELAY_SECONDS=2.0

EXPORT_DIR=exports
LOG_LEVEL=INFO
ALLOW_ORIGINS=*
